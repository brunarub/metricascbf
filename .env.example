# Meta / Instagram
# Token com permissões: instagram_basic, instagram_manage_insights, pages_show_list, pages_read_engagement
# DEVE ser token de longa duração (System User do Business Manager)
META_ACCESS_TOKEN=

# App ID e App Secret do app da Meta (developers.facebook.com > seu app > Configurações Básicas)
# Necessários só para o /api/refresh-token renovar o token automaticamente
META_APP_ID=
META_APP_SECRET=

# Versão da Graph API
GRAPH_API_VERSION=v21.0

# IDs das contas Instagram Business (número interno, não é o @usuario)
# Formato: rotulo:id, separados por vírgula
# Exemplo: copa_do_brasil:17841400000001,brasileirao:17841400000002,brasileiras:17841400000003
IG_ACCOUNTS=

# URL pública do dashboard, usada pelo cron de renovação de token (npm run refresh-token-cron)
DASHBOARD_URL=http://localhost:3001

# Google Sheets (necessário apenas para npm run sync, não para o dashboard web)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Posts
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Brevo (emails de alerta e resumo semanal — HTTP API, sem SMTP)
# Criar conta gratuita em brevo.com → SMTP & API → API Keys
# Verificar o email remetente em Senders & IPs → Senders
BREVO_API_KEY=
BREVO_SENDER=seuemail@gmail.com

# YouTube Data API v3 (para Shorts e vídeos dos canais)
# Criar em console.cloud.google.com → Credenciais → Chave de API → restringir à YouTube Data API v3
YT_API_KEY=
# Formato: label:channelId, separados por vírgula (label deve bater com IG_ACCOUNTS)
YT_ACCOUNTS=copa_do_brasil:UCNXqgvltbKmIBj5ot66slNg,brasileiras:UCALGUym7Kxp-qK20rOtFPzw,brasileirao:UCeWivzR7k1Fmg6juZVJyB2Q

# Senha para o endpoint /api/test-email — OBRIGATÓRIO para o endpoint ficar protegido
ADMIN_SECRET=
